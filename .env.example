# Copy to .env and fill in. .env is gitignored — never commit real keys.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
WATERCOLOR_MODEL=claude-sonnet-4-6
LOG_LEVEL=INFO
# Durable session store (SQLite checkpointer). Gitignored; delete it for a reset.
WATERCOLOR_DB_PATH=watercolor_tutor.sqlite
# Live web search via MCP. Set to false to disable; command launches the server.
WATERCOLOR_WEB_SEARCH=true
WATERCOLOR_MCP_SEARCH_COMMAND=duckduckgo-mcp-server
# Reference-image search via a second MCP server. Set to false to disable.
WATERCOLOR_IMAGE_SEARCH=true
WATERCOLOR_MCP_IMAGE_COMMAND=ddg-mcp
# Observability — LangSmith tracing (OPTIONAL, additive). Omit the key to run untraced.
# LANGSMITH_API_KEY is a SECRET (kept in .env, gitignored), like ANTHROPIC_API_KEY.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=watercolor-tutor
